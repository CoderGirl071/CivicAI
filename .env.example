# Firebase Configuration
# Copy this file to .env and replace with your Firebase project credentials

# Get these values from Firebase Console:
# 1. Go to https://console.firebase.google.com/
# 2. Select your project → Project Settings (gear icon)
# 3. Scroll down to "Your apps" → Select your web app
# 4. Copy the config values

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Enable/Disable Firebase (set to 'false' to use localStorage only)
VITE_USE_FIREBASE=true
